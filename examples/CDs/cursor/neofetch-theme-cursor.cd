# Neofetch Test - Theme and Cursor
# Tests neofetch with different theme and custom cursor style
# Uses dracula theme with underline cursor

Output examples/svgs/cursor/neofetch-theme-cursor.svg

Set Theme dracula
Set Template macos
Set TypingSpeed 30ms
Set FontSize 16
Set Width 1000

# Custom cursor style
Set CursorStyle underline
Set CursorColor #ff79c6

Type "neofetch"

Sleep 500ms

Enter

Sleep 2s

Type "Custom cursor!"

Sleep 500ms

# Move cursor to show underline style
Left
Left
Left
Left
Left

Sleep 1s
