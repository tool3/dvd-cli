# Custom Font Test
# Tests FontFamily setting with a system font
Output examples/svgs/fonts/custom-font-test.svg

Set Width 500
Set Height 200
Set FontSize 16
Set Theme dracula
Set Title "Custom Font"

# Use JetBrains Mono (if installed) or fallback to monospace
Set FontFamily "JetBrains Mono"

Type "echo 'Using JetBrains Mono font'"
Sleep 500ms
Enter
Type "echo 'Or fallback to monospace'"
Sleep 1s
