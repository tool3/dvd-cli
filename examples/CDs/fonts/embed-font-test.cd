# Embedded Font Test
# Embeds JetBrains Mono directly into the SVG for consistent rendering
Output examples/svgs/fonts/embed-font-test.svg

Set Width 550
Set Height 200
Set FontSize 16
Set Theme nord
Set Title "Embedded Font"

# Embed the font file (woff2 format recommended)
Set EmbedFont examples/fonts/JetBrainsMono-Regular.woff2

Type "echo 'JetBrains Mono embedded in SVG'"
Sleep 500ms
Enter
Type "echo 'Works offline, no font install needed'"
Sleep 1s
