# Embedded Font Example
# Demonstrates embedding a custom font directly into the SVG
# The font is base64-encoded, so the SVG works offline without font installation

Output examples/svgs/fonts/embedded-font.svg

Set Width 600
Set Height 250
Set FontSize 18
Set Theme dracula
Set Title "Embedded Font Demo"
Set Template macos

# Embed Firacode - a popular coding font with ligatures
Set EmbedFont examples/CDs/fonts/FiraCode-Regular.woff2

Type "node -e \"console.log('greetings!')\""
Sleep 500ms
Enter
Type "// Font is embedded - works everywhere!"
Sleep 1s
