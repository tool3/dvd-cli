# Word Selection Test
# Tests Alt+Shift+Left/Right for word selection
Output examples/svgs/selection/word-selection-test.svg

Set FontSize 16
Set Title "Word Selection Test"
Set PromptPrefix "\x1b[33m>\x1b[0m "

Type "select these words carefully"
Sleep 500ms

# Select "carefully" by word
Alt+Shift+Left
Sleep 500ms

# Extend selection to include "words "
Alt+Shift+Left
Sleep 500ms

# Replace with "items"
Type "items"
Sleep 500ms

Cmd+Left
Sleep 500ms
Type "echo '"
Cmd+Right
Type "'"

Enter
Sleep 1s
